// Phase 5.0: declarative DAG orchestration ("Minimum Viable Orchestrator").
//
// Like team_presets.rs, this module is a THIN wrapper over the existing
// allowlist spawn path (`ConfigManager::resolve_def` + `PtyManager::spawn_agent`,
// i.e. exactly what `spawn_agent` uses). Workflows introduce no new spawn
// path and no new trust boundary — anything a workflow can launch, a manual
// `spawn_agent` could too.
//
// Wire contract: CONTRACT.md "Phase 5.0 追加契約". Design: docs/spec-phase5-0.md
// (§2.1 "Workflow モデル", §3.1 "M3 Orchestrator 状態機械"). MVO scope:
// pipeline + fan-out, `join_on: all|any`, completion via AgentStatus == done or
// PTY exit(0). Deferred to 5.0.4: supervisor, handoff, retry, timeout,
// join_on: reply/N, `condition:` predicates.
//
// This module is kept OUTSIDE `lib.rs` and outside the session hot path per
// release discipline (phase3.md).

// MVO (Phase 5.0.0.a/b) scaffolding: types, allowlist enforcement, and the
// pipeline/fan-out spawn skeleton. The Queen MCP tools (5.0.0.e) and Tauri
// commands (5.0.0.f) that wire these functions land in follow-up patches, so
// clippy would otherwise flag every symbol here as dead code. Remove this
// `allow(dead_code)` in 5.0.0.e once the tool bindings reference them.
#![allow(dead_code)]

use serde::Serialize;
use std::collections::HashMap;
use std::sync::{Arc, Mutex};
use tauri::{AppHandle, Runtime};

use crate::config::{ConfigManager, WorkflowDef, WorkflowPattern, WorkflowStep};
use crate::queen_store::QueenStore;
use crate::session::{PtyManager, SessionState};

/// Grid-occupancy cap for partial launch, mirrors `TEAM_SESSION_CAP` /
/// frontend `MAX_PANES`. A workflow step that would exceed this is FAILED
/// with "pane limit" rather than spawning a paneless session.
pub const WORKFLOW_SESSION_CAP: usize = 9;

/// ULID-shaped opaque run identifier. Generated by `spawn_workflow` and
/// returned to the caller (frontend / MCP client) for follow-up `join` and
/// `cancel_workflow`. Wire type is a plain string; the concrete format is not
/// part of the contract, only its opacity.
pub type WorkflowRunId = String;

/// Overall workflow lifecycle. Wire values are lowercase.
#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize)]
#[serde(rename_all = "lowercase")]
pub enum WorkflowState {
    Pending,
    Running,
    Succeeded,
    Failed,
    Cancelled,
}

/// One step's lifecycle within a run. `Skipped` is used when a step's
/// predecessor failed and the workflow policy is `fail-fast`; the pane is
/// never spawned.
#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize)]
#[serde(rename_all = "lowercase")]
pub enum StepState {
    Pending,
    Running,
    Succeeded,
    Failed,
    Skipped,
    Cancelled,
}

/// Per-step outcome inside a `WorkflowRun`.
#[derive(Debug, Clone, Serialize)]
#[serde(rename_all = "camelCase")]
pub struct StepOutcome {
    pub step_id: String,
    pub agent: String,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub session_id: Option<u32>,
    pub state: StepState,
    /// Number of times spawn was attempted (increments on retry; MVO always
    /// leaves this at 1 since retry lands in 5.0.4).
    pub attempts: u32,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub error: Option<String>,
}

/// Public view of a workflow run, emitted verbatim on the `workflow-state`
/// Tauri event whenever any field changes.
#[derive(Debug, Clone, Serialize)]
#[serde(rename_all = "camelCase")]
pub struct WorkflowRun {
    pub run_id: WorkflowRunId,
    pub name: String,
    pub state: WorkflowState,
    pub started_at_ms: u64,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub ended_at_ms: Option<u64>,
    pub steps: Vec<StepOutcome>,
}

/// In-memory registry of live and recently-terminated workflow runs. Held as
/// `AppHandle::manage`d state (lib.rs), same pattern as `PtyManager`. MVO
/// keeps the last 100 runs in memory; persistence to the `workflow_runs`
/// SQLite table lands in 5.0.0.c together with the state-machine driver.
#[derive(Default)]
pub struct WorkflowRegistry {
    inner: Arc<Mutex<HashMap<WorkflowRunId, WorkflowRun>>>,
}

impl WorkflowRegistry {
    pub fn new() -> Self {
        Self::default()
    }

    /// Snapshot a run by id. `None` if the run has been evicted or never
    /// existed. Callers get a clone — the registry lock is never held across
    /// an `AppHandle::emit`.
    pub fn get(&self, run_id: &str) -> Option<WorkflowRun> {
        self.inner.lock().ok().and_then(|g| g.get(run_id).cloned())
    }

    /// Snapshot every run currently held. Used by `list_workflow_runs`.
    pub fn list(&self) -> Vec<WorkflowRun> {
        self.inner
            .lock()
            .map(|g| g.values().cloned().collect())
            .unwrap_or_default()
    }

    /// Replace or insert a run. Callers must have prepared the full snapshot
    /// they want to publish; the registry does not merge fields.
    pub fn put(&self, run: WorkflowRun) {
        if let Ok(mut g) = self.inner.lock() {
            g.insert(run.run_id.clone(), run);
        }
    }
}

/// Wall-clock milliseconds since UNIX_EPOCH; monotonic-enough for run
/// bookkeeping, not for scheduling. Panics on system-time regression only
/// (SystemTime::duration_since panics on error, we swallow it to 0 instead).
fn now_ms() -> u64 {
    use std::time::{SystemTime, UNIX_EPOCH};
    SystemTime::now()
        .duration_since(UNIX_EPOCH)
        .map(|d| d.as_millis() as u64)
        .unwrap_or(0)
}

/// Random 24-char ULID-ish id. MVO uses a lightweight scheme (no external
/// `ulid` crate dependency yet) — collision probability is negligible for
/// the 100-run in-memory window. Persistence in 5.0.0.c will switch to real
/// ULIDs if the DB layer prefers them.
fn new_run_id() -> WorkflowRunId {
    use std::time::{SystemTime, UNIX_EPOCH};
    let ts = SystemTime::now()
        .duration_since(UNIX_EPOCH)
        .map(|d| d.as_nanos() as u64)
        .unwrap_or(0);
    // 16-hex nanos + 8-hex process-local counter = 24 chars.
    use std::sync::atomic::{AtomicU32, Ordering};
    static COUNTER: AtomicU32 = AtomicU32::new(0);
    let ctr = COUNTER.fetch_add(1, Ordering::Relaxed);
    format!("wfr_{:016x}{:08x}", ts, ctr)
}

/// The live session id for a definition name, if one exists (any state
/// except Exited). Same helper as `team_presets::live_session_id`; kept
/// duplicated to avoid a fragile cross-module coupling at MVO scope.
fn live_session_id(manager: &PtyManager, name: &str) -> Option<u32> {
    manager
        .list_sessions()
        .into_iter()
        .find(|s| s.state != SessionState::Exited && s.name.as_deref() == Some(name))
        .map(|s| s.id)
}

/// Steps whose `dependsOn` list is empty — the DAG's roots. These are the
/// steps a fresh run may launch first.
fn root_steps(wf: &WorkflowDef) -> Vec<&WorkflowStep> {
    wf.steps
        .iter()
        .filter(|s| s.depends_on.as_deref().unwrap_or(&[]).is_empty())
        .collect()
}

/// Spawn one step through the existing allowlist path, matching the
/// `team_presets::start_team` idempotency + pane-cap semantics.
fn spawn_step<R: Runtime>(
    app: &AppHandle<R>,
    manager: &PtyManager,
    config: &ConfigManager,
    step: &WorkflowStep,
    reuse_existing: bool,
    cols: u16,
    rows: u16,
) -> StepOutcome {
    let agent = step.agent.clone();
    // Idempotent reuse is only valid for singular steps (pipeline). A fan-out
    // copy must ALWAYS get a fresh pane — the whole point of `fanOut: 3` is 3
    // parallel sessions of the same definition, so the team_presets-style
    // "live same-name session -> skip" rule would collapse the fan to 1.
    let reusable = if reuse_existing {
        live_session_id(manager, &agent)
    } else {
        None
    };
    if let Some(existing) = reusable {
        // Same idempotent skip as team_presets — a workflow re-launching a
        // step whose session already exists reuses the existing pane rather
        // than duplicating it.
        return StepOutcome {
            step_id: step.id.clone(),
            agent,
            session_id: Some(existing),
            state: StepState::Running, // caller will observe completion via AgentStatus/exit
            attempts: 1,
            error: None,
        };
    }
    if manager.list_sessions().len() >= WORKFLOW_SESSION_CAP {
        return StepOutcome {
            step_id: step.id.clone(),
            agent,
            session_id: None,
            state: StepState::Failed,
            attempts: 1,
            error: Some(format!("pane limit ({WORKFLOW_SESSION_CAP}) reached")),
        };
    }
    let spawn = config
        .resolve_def(&agent)
        .and_then(|(def, dir)| manager.spawn_agent(app.clone(), &def, &dir, cols, rows));
    match spawn {
        Ok(id) => StepOutcome {
            step_id: step.id.clone(),
            agent,
            session_id: Some(id),
            state: StepState::Running,
            attempts: 1,
            error: None,
        },
        Err(error) => StepOutcome {
            step_id: step.id.clone(),
            agent,
            session_id: None,
            state: StepState::Failed,
            attempts: 1,
            error: Some(error),
        },
    }
}

/// Deliver a step's `kickoff` message to its inbox mailbox (= definition
/// name) via the durable Queen store, same path team_presets uses.
fn deliver_kickoff(
    store: &QueenStore,
    project_dir: &std::path::Path,
    workflow_name: &str,
    step: &WorkflowStep,
) -> Result<(), String> {
    let Some(kickoff) = step.kickoff.as_ref() else {
        return Ok(());
    };
    store
        .send_inbox(
            project_dir,
            format!("queen:workflow/{workflow_name}"),
            step.agent.clone(),
            format!("workflow:{workflow_name} step:{} kickoff", step.id),
            kickoff.clone(),
        )
        .map(|_| ())
}

/// Launch a named workflow. See CONTRACT.md Phase 5.0 §5.0.3 for the exact
/// wire semantics. MVO scope (5.0.0):
///
/// 1. Validate the workflow exists in the loaded config;
/// 2. For `pipeline`: spawn the single root step and deliver its kickoff;
/// 3. For `fan-out`: spawn N parallel copies of each fanOut-marked root step
///    and deliver each one's kickoff;
/// 4. For `supervisor` / `handoff`: return `Err("pattern not implemented in MVO")`
///    (5.0.4 will land these);
/// 5. Return an initial `WorkflowRun` snapshot with state=Running and each
///    launched step in state=Running.
///
/// **DAG progression is NOT implemented here** — the state machine driver
/// that watches for step completion and launches downstream steps lands in
/// 5.0.0.c together with the SQLite persistence layer. Until then, downstream
/// steps stay in `Pending` and the caller must inspect the run via
/// `list_workflow_runs`. This is deliberate: the MVO ships parseable config,
/// spawn-time validation, and the type surface; the runtime driver is a
/// separate concern with its own tests.
#[allow(clippy::too_many_arguments)]
pub fn spawn_workflow<R: Runtime>(
    app: &AppHandle<R>,
    manager: &PtyManager,
    config: &ConfigManager,
    store: &QueenStore,
    registry: &WorkflowRegistry,
    workflow_name: &str,
    cols: u16,
    rows: u16,
) -> Result<WorkflowRun, String> {
    let (cfg, project_dir) = config
        .current()
        .ok_or_else(|| "no config loaded (call load_config first)".to_string())?;
    let wf = cfg
        .workflows
        .as_ref()
        .and_then(|m| m.get(workflow_name))
        .ok_or_else(|| format!("workflow '{workflow_name}' not found in config"))?
        .clone();

    // MVO gates: reject patterns whose runtime driver is not yet implemented.
    match wf.pattern {
        WorkflowPattern::Pipeline | WorkflowPattern::FanOut => {}
        WorkflowPattern::Supervisor | WorkflowPattern::Handoff => {
            return Err(format!(
                "workflow '{workflow_name}': pattern {:?} not implemented in MVO \
                 (lands in Phase 5.0.4)",
                wf.pattern
            ));
        }
    }

    let run_id = new_run_id();
    let started_at_ms = now_ms();
    let mut outcomes: Vec<StepOutcome> = Vec::with_capacity(wf.steps.len());

    // Every non-root step starts Pending.
    for step in &wf.steps {
        let is_root = step.depends_on.as_deref().unwrap_or(&[]).is_empty();
        if !is_root {
            outcomes.push(StepOutcome {
                step_id: step.id.clone(),
                agent: step.agent.clone(),
                session_id: None,
                state: StepState::Pending,
                attempts: 0,
                error: None,
            });
        }
    }

    // Roots launch immediately. fan-out expands roots per fanOut count.
    for step in root_steps(&wf) {
        let copies = match (wf.pattern, step.fan_out) {
            (WorkflowPattern::FanOut, Some(n)) if n >= 2 => n as usize,
            _ => 1,
        };
        // copies == 1 -> singular step (pipeline or un-fanned root): keep the
        // idempotent reuse. copies >= 2 -> fan-out expansion: every copy must
        // spawn fresh.
        let reuse_existing = copies == 1;
        for _ in 0..copies {
            let outcome = spawn_step(app, manager, config, step, reuse_existing, cols, rows);
            // Best-effort kickoff delivery — a failed delivery does NOT flip
            // the step to Failed (the pane is already alive; the agent can
            // still work via manual instruction). The failure is surfaced on
            // the outcome.error field. Same posture team_presets uses.
            if outcome.state == StepState::Running {
                if let Err(err) = deliver_kickoff(store, &project_dir, workflow_name, step) {
                    // Attach as suffix, keeping any earlier error text.
                    let base = outcome.error.clone().unwrap_or_default();
                    let joined = if base.is_empty() {
                        format!("kickoff delivery failed: {err}")
                    } else {
                        format!("{base}; kickoff delivery failed: {err}")
                    };
                    outcomes.push(StepOutcome {
                        error: Some(joined),
                        ..outcome
                    });
                    continue;
                }
            }
            outcomes.push(outcome);
        }
    }

    // Preserve declaration order so callers can render the DAG top-down.
    outcomes.sort_by_key(|o| {
        wf.steps
            .iter()
            .position(|s| s.id == o.step_id)
            .unwrap_or(usize::MAX)
    });

    let state = if outcomes
        .iter()
        .any(|o| o.state == StepState::Running || o.state == StepState::Pending)
    {
        WorkflowState::Running
    } else if outcomes.iter().all(|o| o.state == StepState::Succeeded) {
        WorkflowState::Succeeded
    } else {
        WorkflowState::Failed
    };

    let run = WorkflowRun {
        run_id: run_id.clone(),
        name: workflow_name.to_string(),
        state,
        started_at_ms,
        ended_at_ms: None,
        steps: outcomes,
    };
    registry.put(run.clone());
    Ok(run)
}

/// Cancel a running workflow: kill every step's live PTY, mark remaining
/// pending steps CANCELLED, and set the run to `Cancelled`. Idempotent —
/// a terminal (Succeeded/Failed/Cancelled) run is a no-op that returns
/// the current snapshot.
pub fn cancel_workflow(
    manager: &PtyManager,
    registry: &WorkflowRegistry,
    run_id: &str,
) -> Result<WorkflowRun, String> {
    let mut run = registry
        .get(run_id)
        .ok_or_else(|| format!("workflow run '{run_id}' not found"))?;
    if matches!(
        run.state,
        WorkflowState::Succeeded | WorkflowState::Failed | WorkflowState::Cancelled
    ) {
        return Ok(run);
    }
    for outcome in &mut run.steps {
        match outcome.state {
            StepState::Running => {
                if let Some(id) = outcome.session_id {
                    let _ = manager.kill_pty(id);
                }
                outcome.state = StepState::Cancelled;
            }
            StepState::Pending => outcome.state = StepState::Cancelled,
            _ => {}
        }
    }
    run.state = WorkflowState::Cancelled;
    run.ended_at_ms = Some(now_ms());
    registry.put(run.clone());
    Ok(run)
}

// -----------------------------------------------------------------------------
// Tests
// -----------------------------------------------------------------------------

#[cfg(test)]
mod tests {
    use super::*;
    use crate::config::{parse_config, ConfigManager};

    fn mock_handle() -> tauri::AppHandle<tauri::test::MockRuntime> {
        let app = tauri::test::mock_app();
        app.handle().clone()
    }

    fn harness(yaml: &str) -> (ConfigManager, QueenStore, std::path::PathBuf) {
        let dir = std::env::temp_dir().join(format!(
            "ptygrid-orch-test-{}-{:?}",
            std::process::id(),
            std::thread::current().id()
        ));
        std::fs::create_dir_all(&dir).unwrap();
        let config = ConfigManager::new();
        config.set_for_test(dir.clone(), parse_config(yaml).unwrap());
        let store = QueenStore::open_in_memory().unwrap();
        (config, store, dir)
    }

    const PIPELINE_YAML: &str = "agents:
  - name: a
    cmd: /bin/cat
  - name: b
    cmd: /bin/cat
workflows:
  demo:
    pattern: pipeline
    steps:
      - id: first
        agent: a
        kickoff: hello
      - id: second
        agent: b
        dependsOn: [first]
";

    const FANOUT_YAML: &str = "agents:
  - name: worker
    cmd: /bin/cat
workflows:
  triple:
    pattern: fan-out
    steps:
      - id: candidate
        agent: worker
        fanOut: 3
        joinOn: all
";

    #[test]
    fn spawn_workflow_pipeline_launches_root_and_leaves_downstream_pending() {
        let handle = mock_handle();
        let manager = PtyManager::new();
        let (config, store, dir) = harness(PIPELINE_YAML);
        let registry = WorkflowRegistry::new();

        let run = spawn_workflow(
            &handle, &manager, &config, &store, &registry, "demo", 80, 24,
        )
        .expect("pipeline should spawn root step");

        assert_eq!(run.name, "demo");
        assert_eq!(run.state, WorkflowState::Running);
        assert_eq!(run.steps.len(), 2);
        // Root step: Running with a session id.
        assert_eq!(run.steps[0].step_id, "first");
        assert_eq!(run.steps[0].state, StepState::Running);
        assert!(run.steps[0].session_id.is_some());
        // Downstream step: Pending, no session.
        assert_eq!(run.steps[1].step_id, "second");
        assert_eq!(run.steps[1].state, StepState::Pending);
        assert!(run.steps[1].session_id.is_none());
        // Registry has the run.
        assert!(registry.get(&run.run_id).is_some());

        for s in manager.list_sessions() {
            let _ = manager.kill_pty(s.id);
        }
        let _ = std::fs::remove_dir_all(&dir);
    }

    #[test]
    fn spawn_workflow_fanout_launches_n_parallel_root_steps() {
        let handle = mock_handle();
        let manager = PtyManager::new();
        let (config, store, dir) = harness(FANOUT_YAML);
        let registry = WorkflowRegistry::new();

        let run = spawn_workflow(
            &handle, &manager, &config, &store, &registry, "triple", 80, 24,
        )
        .expect("fan-out should spawn 3 parallel steps");

        assert_eq!(run.state, WorkflowState::Running);
        assert_eq!(run.steps.len(), 3, "fanOut: 3 expands into 3 outcome rows");
        for outcome in &run.steps {
            assert_eq!(outcome.step_id, "candidate");
            assert_eq!(outcome.agent, "worker");
            assert_eq!(outcome.state, StepState::Running);
            assert!(outcome.session_id.is_some());
        }
        // Three live sessions on the grid.
        assert_eq!(manager.list_sessions().len(), 3);

        for s in manager.list_sessions() {
            let _ = manager.kill_pty(s.id);
        }
        let _ = std::fs::remove_dir_all(&dir);
    }

    #[test]
    fn cancel_workflow_kills_running_and_marks_pending_cancelled() {
        let handle = mock_handle();
        let manager = PtyManager::new();
        let (config, store, dir) = harness(PIPELINE_YAML);
        let registry = WorkflowRegistry::new();

        let run = spawn_workflow(
            &handle, &manager, &config, &store, &registry, "demo", 80, 24,
        )
        .unwrap();
        let cancelled = cancel_workflow(&manager, &registry, &run.run_id).unwrap();

        assert_eq!(cancelled.state, WorkflowState::Cancelled);
        assert_eq!(cancelled.steps[0].state, StepState::Cancelled);
        assert_eq!(cancelled.steps[1].state, StepState::Cancelled);
        assert!(cancelled.ended_at_ms.is_some());

        // Second cancel is idempotent.
        let again = cancel_workflow(&manager, &registry, &run.run_id).unwrap();
        assert_eq!(again.state, WorkflowState::Cancelled);

        let _ = std::fs::remove_dir_all(&dir);
    }

    #[test]
    fn unknown_workflow_and_missing_config_error() {
        let handle = mock_handle();
        let manager = PtyManager::new();
        let (config, store, dir) = harness(PIPELINE_YAML);
        let registry = WorkflowRegistry::new();

        let err = spawn_workflow(
            &handle, &manager, &config, &store, &registry, "nope", 80, 24,
        )
        .unwrap_err();
        assert!(err.contains("'nope'"), "unknown-workflow message: {err}");

        let empty = ConfigManager::new();
        let err = spawn_workflow(&handle, &manager, &empty, &store, &registry, "demo", 80, 24)
            .unwrap_err();
        assert!(
            err.contains("no config loaded"),
            "empty-config message: {err}"
        );
        let _ = std::fs::remove_dir_all(&dir);
    }

    #[test]
    fn fanout_yaml_parses_pattern_and_fan_out_field() {
        // Diagnostic for the fan-out spawn failure: pin down whether the
        // `pattern: fan-out` YAML value deserializes to WorkflowPattern::FanOut
        // and `fanOut: 3` to fan_out: Some(3). If this test passes, parsing is
        // fine and the bug is in the spawn loop. If it fails, we need to fix
        // the serde attributes on WorkflowPattern / WorkflowStep.
        let cfg = crate::config::parse_config(FANOUT_YAML)
            .expect("FANOUT_YAML should parse cleanly");
        let workflows = cfg.workflows.expect("workflows: block should be present");
        let wf = workflows.get("triple").expect("workflow 'triple' should exist");
        assert_eq!(
            wf.pattern,
            crate::config::WorkflowPattern::FanOut,
            "pattern: fan-out should deserialize to WorkflowPattern::FanOut, got {:?}",
            wf.pattern
        );
        assert_eq!(wf.steps.len(), 1, "workflow should have 1 declared step");
        assert_eq!(
            wf.steps[0].fan_out,
            Some(3),
            "fanOut: 3 should deserialize to fan_out: Some(3), got {:?}",
            wf.steps[0].fan_out
        );
    }

    #[test]
    fn supervisor_pattern_is_rejected_with_typed_error() {
        let handle = mock_handle();
        let manager = PtyManager::new();
        let yaml = "agents:
  - name: a
    cmd: /bin/cat
workflows:
  sup:
    pattern: supervisor
    steps:
      - id: root
        agent: a
      - id: child
        agent: a
        dependsOn: [root]
";
        let (config, store, dir) = harness(yaml);
        let registry = WorkflowRegistry::new();

        let err = spawn_workflow(&handle, &manager, &config, &store, &registry, "sup", 80, 24)
            .unwrap_err();
        assert!(
            err.contains("not implemented in MVO"),
            "supervisor should be a typed defer, got: {err}"
        );
        let _ = std::fs::remove_dir_all(&dir);
    }
}
